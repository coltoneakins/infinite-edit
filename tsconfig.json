{
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "ES2024",
		"lib": [
			"ES2024",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true
	}
}